# Database (PostgreSQL) — use your own connection string; never commit real credentials
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
# Optional: set to true if the DB uses self-signed certs
# DATABASE_SSL_NO_VERIFY=true

# Locales shown in the UI (language switcher + region picker). Omit = all codes in lib/i18n-config.ts KNOWN_LOCALE_CODES
# Super admin can override this per deployment via Platform → Languages (stores platform_settings.approved_locales).
# Examples:
#   NEXT_PUBLIC_APPROVED_LOCALES=en,es
#   NEXT_PUBLIC_APPROVED_LOCALES=en,es,ar,fr
# Omit French until fr.json is reviewed: do not include "fr" until ready.
# NEXT_PUBLIC_APPROVED_LOCALES=en,es,ar,fr

# Auth — generate AUTH_SECRET: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-at-least-32-chars
# Production: set AUTH_TRUST_HOST=true and AUTH_URL in deployment env
# AUTH_TRUST_HOST=true
# AUTH_URL=https://your-domain.com

# Tenant clinic URLs use {slug}.thefertilityos.com after login on www. That needs wildcard DNS (*.thefertilityos.com).
# If wildcard is not set up yet, set this so users stay on www (session still has the correct tenant).
# DISABLE_TENANT_SUBDOMAIN_REDIRECT=1

# When using tenant subdomains, set so the auth session cookie is sent on www AND *.thefertilityos.com (leading dot).
# Production example: AUTH_COOKIE_DOMAIN=.thefertilityos.com
# Omit locally (localhost). Users may need to sign in once after enabling this.
# AUTH_COOKIE_DOMAIN=.thefertilityos.com

# OAuth — Google (optional; omit to disable Google sign-in)
# AUTH_GOOGLE_ID=your-google-client-id
# AUTH_GOOGLE_SECRET=your-google-client-secret
# Set NEXT_PUBLIC_OAUTH_GOOGLE=1 to show "Sign in with Google" on the login page
# NEXT_PUBLIC_OAUTH_GOOGLE=1

# OAuth — Microsoft / Azure AD (optional; omit to disable Microsoft sign-in)
# AUTH_MICROSOFT_ID=your-azure-ad-client-id
# AUTH_MICROSOFT_SECRET=your-azure-ad-client-secret
# Optional: Azure AD tenant ID (default: "common" for multi-tenant)
# AUTH_MICROSOFT_TENANT_ID=common
# Set NEXT_PUBLIC_OAUTH_MICROSOFT=1 to show "Sign in with Microsoft" on the login page
# NEXT_PUBLIC_OAUTH_MICROSOFT=1

# Telemedicine (Daily.co) — for "Start video call" on appointments
# DAILY_API_KEY=your-daily-api-key

# Super Admin dashboard: optional rough MRR line (active+trialing+past_due subs × this USD)
# SUPER_ADMIN_ESTIMATED_MRR_USD_PER_ACTIVE_SUB=99

# Stripe (subscriptions / Checkout) — optional if you configure keys in Super Admin → Payment gateways
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook URL (Stripe Dashboard → destination): https://your-host/api/webhooks/stripe  (this app does not use /api/payment/webhook)
# Optional reference only (not read by app code):
# STRIPE_WEBHOOK_DESTINATION_ID=ed_test_...
# STRIPE_WEBHOOK_DESTINATION_NAME=my-endpoint
# STRIPE_WEBHOOK_ENDPOINT_URL=https://your-host/api/webhooks/stripe
# DB values override these when set. Set payment_provider to "none" in Payment gateways to disable Stripe site-wide.
